{
  "name": "jusik101",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pages:build": "next-on-pages",
    "pages:dev": "pnpm pages:build && wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat --port=3000",
    "d1:seed-local": "pnpm exec wrangler d1 execute jusik101-companies --local --file=migrations/0001_companies.sql && pnpm exec wrangler d1 execute jusik101-companies --local --file=migrations/0002_market_data.sql",
    "d1:export-prod": "pnpm exec wrangler d1 export jusik101-companies --remote --output=.wrangler/prod-dump.sql",
    "d1:import-local": "pnpm exec wrangler d1 execute jusik101-companies --local --file=.wrangler/prod-dump.sql",
    "pages:deploy": "pnpm pages:build && wrangler pages deploy .vercel/output/static --project-name=jusik101"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.7.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260430.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  }
}
